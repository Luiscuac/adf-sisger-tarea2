{
	"name": "df_gold_dim_paciente",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_vacunaciones_consolidadas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_paciente",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_completo as string,",
				"          fecha_nacimiento as date,",
				"          sexo as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT \\n    paciente_id,\\n    ci_paciente,\\n    nombre_paciente + \\' \\' + apellido_paterno + \\' \\' + ISNULL(apellido_materno, \\'\\') AS nombre_completo,\\n    fecha_nacimiento,\\n    sexo,\\n    municipio_residencia,\\n    comunidad_indigena\\nFROM silver.vacunaciones_consolidadas\\nWHERE paciente_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paciente_key as integer,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_completo as string,",
				"          sexo as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as boolean,",
				"          fecha_nacimiento as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_completo,",
				"          sexo,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_nacimiento",
				"     )) ~> sink1"
			]
		}
	}
}