{
	"name": "bronze_catalogo_vacunas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_vacunas_pai_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "FiltrarVacunasValidas"
				},
				{
					"name": "EstandarizarTextos"
				},
				{
					"name": "CastearNumerosYDecimales"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as string,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as string,",
				"          edad_maxima_dias as string,",
				"          intervalo_minimo_dias as string,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as string,",
				"          condicion_especial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 filter(!isNull(vacuna_id) && trim(vacuna_id) != '') ~> FiltrarVacunasValidas",
				"FiltrarVacunasValidas derive(vacuna_id = trim(vacuna_id),",
				"          vacuna_nombre = trim(vacuna_nombre),",
				"          via_administracion = upper(trim(via_administracion)),",
				"          condicion_especial = iif(isNull(condicion_especial) || trim(condicion_especial) == '', 'NINGUNA', upper(trim(condicion_especial)))) ~> EstandarizarTextos",
				"EstandarizarTextos derive(numero_dosis = toInteger(numero_dosis),",
				"          edad_minima_dias = toInteger(edad_minima_dias),",
				"          edad_maxima_dias = toInteger(edad_maxima_dias),",
				"          intervalo_minimo_dias = iif(isNull(intervalo_minimo_dias) || trim(intervalo_minimo_dias) == '', toInteger(null()), toInteger(intervalo_minimo_dias)),",
				"          dosis_ml = toDecimal(dosis_ml, 10, 2)) ~> CastearNumerosYDecimales"
			]
		}
	}
}