{
	"name": "bronze_catalogo_establecimientos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_establecimientos",
						"type": "DatasetReference"
					},
					"name": "CargaSilverEstablecimientos"
				}
			],
			"transformations": [
				{
					"name": "FiltrarEstablecimientosActivos"
				},
				{
					"name": "LimpiarCamposTexto"
				},
				{
					"name": "CastearTiposTecnicos"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 filter(!isNull(establecimiento_id) && trim(establecimiento_id) != '') ~> FiltrarEstablecimientosActivos",
				"FiltrarEstablecimientosActivos derive(nombre_establecimiento = upper(trim(nombre_establecimiento)),",
				"          {tipo_establecimiento } = upper(trim(tipo_establecimiento)),",
				"          red_salud = iif(isNull(red_salud) || trim(red_salud) == '', 'SIN RED ASIGNADA', upper(trim(red_salud))),",
				"          municipio = trim(municipio),",
				"          zona = upper(trim(zona))) ~> LimpiarCamposTexto",
				"LimpiarCamposTexto derive(nivel_atencion = toInteger(nivel_atencion),",
				"          latitud = toDecimal(     iif(locate('.', replace(trim(latitud), ',', '.')) > 0,          left(replace(trim(latitud), ',', '.'), locate('.', replace(trim(latitud), ',', '.'))) + replace(substring(replace(trim(latitud), ',', '.'), locate('.', replace(trim(latitud), ',', '.')) + 1, length(latitud)), '.', ''),          replace(trim(latitud), ',', '.')     ),      10, 6 ),",
				"          longitud = toDecimal(     iif(locate('.', replace(trim(longitud), ',', '.')) > 0,          left(replace(trim(longitud), ',', '.'), locate('.', replace(trim(longitud), ',', '.'))) + replace(substring(replace(trim(longitud), ',', '.'), locate('.', replace(trim(longitud), ',', '.')) + 1, length(longitud)), '.', ''),          replace(trim(longitud), ',', '.')     ),      10, 6 ),",
				"          tiene_cadena_frio = toBoolean(tiene_cadena_frio),",
				"          activo = toBoolean(activo)) ~> CastearTiposTecnicos",
				"CastearTiposTecnicos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as integer,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as decimal(10,6),",
				"          longitud as decimal(10,6),",
				"          tiene_cadena_frio as boolean,",
				"          activo as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          departamento,",
				"          municipio,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     )) ~> CargaSilverEstablecimientos"
			]
		}
	}
}