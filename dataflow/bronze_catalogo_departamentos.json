{
	"name": "bronze_catalogo_departamentos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_departamentos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_departamentos",
						"type": "DatasetReference"
					},
					"name": "CargarSilverCatologoDepartamentos"
				}
			],
			"transformations": [
				{
					"name": "FiltrarIDsValidos"
				},
				{
					"name": "EstandarizarTextos"
				},
				{
					"name": "ConvertirTiposDato"
				}
			],
			"scriptLines": [
				"source(output(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as string,",
				"          poblacion_depto_estimada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 filter(!isNull(municipio_id) && trim(municipio_id) != '') ~> FiltrarIDsValidos",
				"FiltrarIDsValidos derive(municipio_id = trim(municipio_id),",
				"          municipio_nombre = trim(municipio_nombre),",
				"          departamento = upper(trim(departamento)),",
				"          zona_geografica = upper(trim(zona_geografica))) ~> EstandarizarTextos",
				"EstandarizarTextos derive(es_capital_departamental = toBoolean(es_capital_departamental),",
				"          poblacion_depto_estimada = toInteger(poblacion_depto_estimada)) ~> ConvertirTiposDato",
				"ConvertirTiposDato sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as boolean,",
				"          poblacion_depto_estimada as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> CargarSilverCatologoDepartamentos"
			]
		}
	}
}